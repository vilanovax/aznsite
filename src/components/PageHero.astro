---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
}
const { eyebrow, title, subtitle } = Astro.props;
---

<section class="relative overflow-hidden bg-ink-900 pt-16 pb-20 px-5 lg:px-8">
  <!-- subtle grid + glow -->
  <div
    class="absolute inset-0 opacity-[0.07]"
    style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 56px 56px;"
  >
  </div>
  <div class="absolute -top-32 start-1/2 -translate-x-1/2 w-[40rem] h-[40rem] rounded-full bg-brand-600/20 blur-3xl"></div>

  <div class="relative mx-auto max-w-4xl text-center animate-fade-up">
    {eyebrow && <span class="inline-block text-sm font-semibold text-brand-300 mb-4">{eyebrow}</span>}
    <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight">{title}</h1>
    {subtitle && <p class="mt-5 text-lg text-ink-300 max-w-2xl mx-auto leading-8">{subtitle}</p>}
  </div>
</section>
