---
import Icon from './Icon.astro';
interface Props {
  icon: string;
  title: string;
  summary: string;
  points?: string[];
  delay?: number;
}
const { icon, title, summary, points = [], delay = 0 } = Astro.props;
---

<article
  class="reveal group relative flex flex-col rounded-2xl border border-ink-100 bg-white p-7 transition-all duration-300 hover:border-brand-200 hover:shadow-xl hover:shadow-brand-900/5 hover:-translate-y-1"
  data-delay={`${delay}ms`}
>
  <div
    class="grid place-items-center w-14 h-14 rounded-xl bg-brand-50 text-brand-600 transition-colors group-hover:bg-brand-600 group-hover:text-white"
  >
    <Icon name={icon} class="w-7 h-7" />
  </div>
  <h3 class="mt-5 text-xl font-bold text-ink-900">{title}</h3>
  <p class="mt-3 text-ink-500 leading-7">{summary}</p>
  {
    points.length > 0 && (
      <ul class="mt-5 space-y-2.5 border-t border-ink-100 pt-5">
        {points.map((p) => (
          <li class="flex items-start gap-2.5 text-sm text-ink-600">
            <Icon name="check" class="w-4 h-4 mt-1 text-brand-500 shrink-0" />
            <span>{p}</span>
          </li>
        ))}
      </ul>
    )
  }
</article>
