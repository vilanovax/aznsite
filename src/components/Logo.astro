---
import { site } from '../data/site.js';
interface Props {
  variant?: 'dark' | 'light';
}
const { variant = 'dark' } = Astro.props;
const textColor = variant === 'light' ? 'text-white' : 'text-ink-900';
const subColor = variant === 'light' ? 'text-white/60' : 'text-ink-400';
---

<a href="/" class="flex items-center gap-2.5 group" aria-label={site.name}>
  <span
    class="grid place-items-center w-10 h-10 rounded-xl bg-brand-600 text-white font-bold text-lg shrink-0 transition-transform group-hover:scale-105"
  >
    آ
  </span>
  <span class="flex flex-col leading-tight">
    <span class={`font-bold text-base ${textColor}`}>{site.shortName}</span>
    <span class={`hidden sm:block text-[11px] tracking-wide ${subColor}`}>{site.tagline}</span>
  </span>
</a>
