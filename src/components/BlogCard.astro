---
import Icon from './Icon.astro';
interface Props {
  href: string;
  title: string;
  description: string;
  category: string;
  pubDate: Date;
  readingTime?: string;
  delay?: number;
}
const { href, title, description, category, pubDate, readingTime, delay = 0 } =
  Astro.props;

const dateStr = new Intl.DateTimeFormat('fa-IR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(pubDate);
---

<article
  class="reveal group relative flex flex-col rounded-2xl border border-ink-100 bg-white overflow-hidden transition-all duration-300 hover:border-brand-200 hover:shadow-xl hover:shadow-brand-900/5 hover:-translate-y-1"
  data-delay={`${delay}ms`}
>
  <!-- decorative cover -->
  <div class="relative h-44 bg-gradient-to-br from-brand-500 to-brand-700 overflow-hidden">
    <div class="absolute inset-0 opacity-20" style="background-image: radial-gradient(circle at 20% 20%, white 1px, transparent 1px); background-size: 22px 22px;"></div>
    <span class="absolute bottom-4 start-4 z-10 inline-block rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-brand-700">
      {category}
    </span>
  </div>

  <div class="flex flex-1 flex-col p-6">
    <div class="flex items-center gap-3 text-xs text-ink-400">
      <span>{dateStr}</span>
      {readingTime && (<><span class="text-ink-200">•</span><span>{readingTime}</span></>)}
    </div>
    <h3 class="mt-3 text-lg font-bold text-ink-900 leading-7 group-hover:text-brand-700 transition-colors">
      <a href={href} class="after:absolute after:inset-0">{title}</a>
    </h3>
    <p class="mt-3 text-sm leading-7 text-ink-500 flex-1">{description}</p>
    <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600">
      ادامه مطلب
      <Icon name="arrow" class="w-4 h-4 transition-transform group-hover:-translate-x-1" />
    </span>
  </div>
</article>
