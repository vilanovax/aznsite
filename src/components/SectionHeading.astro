---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'start';
  light?: boolean;
}
const { eyebrow, title, subtitle, align = 'center', light = false } = Astro.props;
const alignCls = align === 'center' ? 'text-center mx-auto' : 'text-start';
---

<div class={`max-w-2xl ${alignCls} reveal`}>
  {
    eyebrow && (
      <span class={`inline-block text-sm font-semibold mb-3 ${light ? 'text-brand-300' : 'text-brand-600'}`}>
        {eyebrow}
      </span>
    )
  }
  <h2 class={`text-3xl sm:text-4xl font-bold leading-tight ${light ? 'text-white' : 'text-ink-900'}`}>
    {title}
  </h2>
  {
    subtitle && (
      <p class={`mt-4 text-lg leading-8 ${light ? 'text-ink-300' : 'text-ink-500'}`}>
        {subtitle}
      </p>
    )
  }
</div>
