---
import { site, nav, services } from '../data/site.js';
import Icon from './Icon.astro';
// سال شمسی جاری با ارقام فارسی (دقیق، بر اساس تقویم جلالی)
const jYear = new Intl.DateTimeFormat('fa-IR-u-ca-persian', {
  year: 'numeric',
}).format(new Date());
---

<footer class="bg-ink-900 text-ink-300">
  <div class="mx-auto max-w-7xl px-5 lg:px-8 py-16">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <div class="flex items-center gap-2.5 mb-4">
          <span class="grid place-items-center w-10 h-10 rounded-xl bg-brand-600 text-white font-bold text-lg">آ</span>
          <span class="font-bold text-white">{site.shortName}</span>
        </div>
        <p class="text-sm leading-7 text-ink-400 max-w-xs">
          {site.description}
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white font-semibold mb-4">دسترسی سریع</h3>
        <ul class="space-y-2.5 text-sm">
          {
            nav.map((item) => (
              <li>
                <a href={item.href} class="hover:text-brand-300 transition-colors">
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold mb-4">خدمات ما</h3>
        <ul class="space-y-2.5 text-sm">
          {
            services.slice(0, 5).map((s) => (
              <li>
                <a href="/services/" class="hover:text-brand-300 transition-colors">
                  {s.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4">تماس با ما</h3>
        <ul class="space-y-3.5 text-sm">
          <li class="flex items-start gap-3">
            <Icon name="pin" class="w-5 h-5 mt-0.5 text-brand-400 shrink-0" />
            <span class="leading-7">{site.address}</span>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="phone" class="w-5 h-5 text-brand-400 shrink-0" />
            <a href={`tel:${site.phoneHref}`} class="tabular hover:text-brand-300 transition-colors" dir="ltr">{site.phone}</a>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="mail" class="w-5 h-5 text-brand-400 shrink-0" />
            <a href={`mailto:${site.email}`} class="hover:text-brand-300 transition-colors" dir="ltr">{site.email}</a>
          </li>
          <li class="flex items-center gap-3">
            <Icon name="clock" class="w-5 h-5 text-brand-400 shrink-0" />
            <span>{site.workingHours}</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-ink-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-ink-500">
      <p>© {jYear} {site.name}. تمامی حقوق محفوظ است.</p>
      <div class="flex items-center gap-4">
        {
          site.socials.map((s) => (
            <a href={s.href} class="hover:text-brand-300 transition-colors">
              {s.label}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
