---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import BlogCard from '../components/BlogCard.astro';
import CtaSection from '../components/CtaSection.astro';
import TrustBar from '../components/TrustBar.astro';
import Icon from '../components/Icon.astro';
import { site, services, stats, values } from '../data/site.js';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout>
  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden bg-ink-900">
    <div
      class="absolute inset-0 opacity-[0.06]"
      style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 56px 56px;"
    >
    </div>
    <div class="absolute -top-40 -start-20 w-[36rem] h-[36rem] rounded-full bg-brand-600/25 blur-3xl"></div>
    <div class="absolute top-20 -end-40 w-[32rem] h-[32rem] rounded-full bg-brand-500/15 blur-3xl"></div>

    <div class="relative mx-auto max-w-7xl px-5 lg:px-8 pt-20 pb-24 lg:pt-28 lg:pb-32">
      <div class="max-w-3xl animate-fade-up">
        <span class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-sm text-brand-200">
          <span class="w-2 h-2 rounded-full bg-brand-400"></span>
          دارای رتبه الف جامعه حسابداران رسمی ایران
        </span>
        <h1 class="mt-6 text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-[1.15]">
          شفافیت مالی، <br class="hidden sm:block" />
          پایه‌ی اعتماد و <span class="text-brand-400">رشد پایدار</span>
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-ink-300 leading-9 max-w-2xl">
          {site.description}
        </p>
        <div class="mt-9 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact/"
            class="inline-flex items-center justify-center gap-2 rounded-xl bg-brand-500 px-7 py-3.5 font-semibold text-white transition-all hover:bg-brand-400 hover:shadow-lg hover:shadow-brand-500/25"
          >
            درخواست مشاوره رایگان
            <Icon name="arrow" class="w-5 h-5" />
          </a>
          <a
            href="/services/"
            class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/20 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-white/10"
          >
            مشاهده خدمات
          </a>
        </div>
      </div>
    </div>

    <!-- floating stats bar -->
    <div class="relative mx-auto max-w-7xl px-5 lg:px-8 pb-0">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-px overflow-hidden rounded-t-2xl bg-white/10 -mb-px">
        {
          stats.map((s) => (
            <div class="bg-ink-900/80 backdrop-blur px-6 py-7 text-center">
              <div class="text-3xl sm:text-4xl font-bold text-white tabular">{s.value}</div>
              <div class="mt-1.5 text-sm text-ink-400">{s.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== TRUST BAR ===== -->
  <TrustBar />

  <!-- ===== VALUES / WHY US ===== -->
  <section class="px-5 lg:px-8 py-20 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <SectionHeading
        eyebrow="چرا آزموده کاران؟"
        title="تعهد ما، آرامش خاطر شماست"
        subtitle="ترکیبی از تخصص، استقلال حرفه‌ای و دقت که سازمان شما برای تصمیم‌گیری مطمئن به آن نیاز دارد."
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          values.map((v, i) => (
            <div
              class="reveal rounded-2xl bg-ink-50 p-7 transition-colors hover:bg-brand-50"
              data-delay={`${i * 80}ms`}
            >
              <div class="grid place-items-center w-11 h-11 rounded-lg bg-white text-brand-600 shadow-sm">
                <Icon name={v.icon} class="w-6 h-6" />
              </div>
              <h3 class="mt-4 font-bold text-ink-900">{v.title}</h3>
              <p class="mt-2 text-sm leading-7 text-ink-500">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="bg-ink-50/60 px-5 lg:px-8 py-20 lg:py-24">
    <div class="mx-auto max-w-7xl">
      <SectionHeading
        eyebrow="خدمات ما"
        title="راهکارهای جامع مالی و حسابرسی"
        subtitle="مجموعه‌ای کامل از خدمات تخصصی برای پاسخ به نیازهای متنوع کسب‌وکار شما."
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((s, i) => (
            <ServiceCard
              icon={s.icon}
              title={s.title}
              summary={s.summary}
              points={s.points}
              delay={(i % 3) * 90}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== BLOG PREVIEW ===== -->
  {
    posts.length > 0 && (
      <section class="px-5 lg:px-8 py-20 lg:py-24">
        <div class="mx-auto max-w-7xl">
          <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
            <SectionHeading
              align="start"
              eyebrow="مقالات و دانش"
              title="تازه‌ترین مطالب"
              subtitle="یادداشت‌ها و تحلیل‌های کارشناسان ما در حوزه حسابرسی، مالیات و مدیریت مالی."
            />
            <a
              href="/blog/"
              class="reveal shrink-0 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-700"
            >
              همه مقالات
              <Icon name="arrow" class="w-4 h-4" />
            </a>
          </div>
          <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((p, i) => (
              <BlogCard
                href={`/blog/${p.id}/`}
                title={p.data.title}
                description={p.data.description}
                category={p.data.category}
                pubDate={p.data.pubDate}
                readingTime={p.data.readingTime}
                delay={i * 90}
              />
            ))}
          </div>
        </div>
      </section>
    )
  }

  <CtaSection />
</BaseLayout>
