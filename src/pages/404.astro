---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="صفحه یافت نشد">
  <section class="px-5 lg:px-8 py-28 text-center">
    <div class="mx-auto max-w-lg">
      <div class="text-7xl font-bold text-brand-600 tabular">۴۰۴</div>
      <h1 class="mt-4 text-2xl font-bold text-ink-900">صفحه مورد نظر یافت نشد</h1>
      <p class="mt-3 text-ink-500 leading-8">
        ممکن است آدرس را اشتباه وارد کرده باشید یا صفحه جابه‌جا شده باشد.
      </p>
      <a href="/" class="mt-8 inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3 font-semibold text-white transition-colors hover:bg-brand-700">
        بازگشت به صفحه اصلی
      </a>
    </div>
  </section>
</BaseLayout>
