---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CtaSection from '../components/CtaSection.astro';
import Icon from '../components/Icon.astro';
import { services } from '../data/site.js';

const process = [
  { n: '۱', title: 'بررسی اولیه', text: 'شناخت کسب‌وکار، نیازها و تعیین دامنه کار.' },
  { n: '۲', title: 'برنامه‌ریزی', text: 'طراحی رویکرد و زمان‌بندی متناسب با ریسک‌ها.' },
  { n: '۳', title: 'اجرا', text: 'انجام رسیدگی‌ها و گردآوری شواهد لازم.' },
  { n: '۴', title: 'گزارش‌گری', text: 'ارائه گزارش شفاف همراه با پیشنهادهای کاربردی.' },
];
---

<BaseLayout title="خدمات" description="خدمات حسابرسی، مالیاتی، مشاوره مدیریت و مالی موسسه آزموده کاران.">
  <PageHero
    eyebrow="خدمات ما"
    title="راهکارهای حرفه‌ای برای هر نیاز"
    subtitle="از حسابرسی صورت‌های مالی تا مشاوره مدیریت؛ مجموعه‌ای کامل از خدمات تخصصی در کنار شما."
  />

  <section class="px-5 lg:px-8 py-20">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((s, i) => (
            <ServiceCard
              icon={s.icon}
              title={s.title}
              summary={s.summary}
              points={s.points}
              delay={(i % 3) * 90}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="bg-ink-900 px-5 lg:px-8 py-20 lg:py-24 relative overflow-hidden">
    <div class="absolute -bottom-32 start-1/2 -translate-x-1/2 w-[40rem] h-[40rem] rounded-full bg-brand-600/15 blur-3xl"></div>
    <div class="relative mx-auto max-w-7xl">
      <div class="max-w-2xl mx-auto text-center reveal">
        <span class="text-sm font-semibold text-brand-300">روش کار ما</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-white">یک فرایند شفاف و حرفه‌ای</h2>
        <p class="mt-4 text-ink-300 leading-8">در هر پروژه، مسیری روشن و گام‌به‌گام را دنبال می‌کنیم تا بهترین نتیجه حاصل شود.</p>
      </div>
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          process.map((p, i) => (
            <div class="reveal rounded-2xl border border-white/10 bg-white/5 p-7" data-delay={`${i * 90}ms`}>
              <div class="grid place-items-center w-12 h-12 rounded-xl bg-brand-500 text-white text-xl font-bold tabular">{p.n}</div>
              <h3 class="mt-5 text-lg font-bold text-white">{p.title}</h3>
              <p class="mt-2 text-sm leading-7 text-ink-300">{p.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>
