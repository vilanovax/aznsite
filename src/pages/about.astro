---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaSection from '../components/CtaSection.astro';
import Icon from '../components/Icon.astro';
import { site, values, affiliations } from '../data/site.js';

// واقعیت‌های تأییدشده به‌جای آمار نمونه
const facts = [
  { value: 'رتبه الف', label: 'جامعه حسابداران رسمی ایران' },
  { value: '۱۳۸۵', label: 'آغاز مشارکت بین‌المللی' },
];
---

<BaseLayout
  title="درباره ما"
  description="درباره موسسه حسابرسی آزموده کاران؛ دارای رتبه الف جامعه حسابداران رسمی ایران، عضو انجمن‌های حرفه‌ای و دارای مشارکت بین‌المللی."
>
  <PageHero
    eyebrow="درباره ما"
    title="موسسه حسابرسی آزموده کاران"
    subtitle="با شعار «ما دقیق هستیم»؛ شریک مطمئن سازمان‌ها در مسیر شفافیت مالی و رشد پایدار."
  />

  <!-- Intro + mission -->
  <section class="px-5 lg:px-8 py-20">
    <div class="mx-auto max-w-7xl grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="reveal">
        <span class="text-sm font-semibold text-brand-600">داستان ما</span>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold text-ink-900 leading-tight">
          دقت و استقلال، پایه‌ی اعتماد
        </h2>
        <div class="mt-6 space-y-4 text-ink-600 leading-8">
          <p>
            موسسه حسابرسی آزموده کاران افتخار ارائه خدمات حسابرسی و مشاوره مدیریت باکیفیت بالا را دارد. اعضای موسسه علاوه بر عضویت در جامعه حسابداران رسمی ایران، انجمن حسابداران خبره، انجمن حسابداری ایران و انجمن حسابرسان داخلی ایران، از اعتماد و همکاری سازمان‌های معتبری چون سازمان بورس اوراق بهادار، سازمان ملل متحد، بانک جهانی، بانک توسعه اسلامی و اتحادیه پارلمان‌های کشورهای اسلامی بهره‌مند هستند.
          </p>
          <p>
            موسسه از سال ۱۳۸۵ با مشارکت بین‌المللی با موسسه Horwath MAK (از موسسات بزرگ حسابرسی در امارات) فعالیت بین‌المللی خود را گسترش داده است. باور ما این است که حسابرسی دقیق و مستقل، فراتر از یک الزام قانونی، ابزاری برای ساختن اعتماد و خلق ارزش پایدار است.
          </p>
        </div>
        <div class="mt-8 grid grid-cols-2 gap-4">
          {
            facts.map((f) => (
              <div class="rounded-xl border border-ink-100 p-5">
                <div class="text-2xl font-bold text-brand-600 tabular">{f.value}</div>
                <div class="mt-1 text-sm text-ink-500 leading-6">{f.label}</div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- mission/vision cards -->
      <div class="reveal space-y-5" data-delay="120ms">
        <div class="rounded-2xl bg-brand-600 p-8 text-white">
          <Icon name="compliance" class="w-9 h-9 text-brand-200" />
          <h3 class="mt-4 text-xl font-bold">ماموریت ما</h3>
          <p class="mt-3 leading-8 text-brand-50">
            ارائه خدمات حرفه‌ای حسابرسی و مالی با بالاترین استانداردهای دقت، استقلال و اخلاق حرفه‌ای — چون «ما دقیق هستیم».
          </p>
        </div>
        <div class="rounded-2xl border border-ink-100 bg-white p-8">
          <Icon name="advisory" class="w-9 h-9 text-brand-600" />
          <h3 class="mt-4 text-xl font-bold text-ink-900">چشم‌انداز ما</h3>
          <p class="mt-3 leading-8 text-ink-600">
            تبدیل‌شدن به نخستین انتخاب سازمان‌ها برای خدمات حسابرسی و مشاوره مالی مبتنی بر اعتماد و نوآوری.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-ink-50/60 px-5 lg:px-8 py-20">
    <div class="mx-auto max-w-7xl">
      <SectionHeading eyebrow="ارزش‌های ما" title="اصولی که به آن پایبندیم" />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          values.map((v, i) => (
            <div class="reveal rounded-2xl bg-white p-7 border border-ink-100" data-delay={`${i * 80}ms`}>
              <div class="grid place-items-center w-11 h-11 rounded-lg bg-brand-50 text-brand-600">
                <Icon name={v.icon} class="w-6 h-6" />
              </div>
              <h3 class="mt-4 font-bold text-ink-900">{v.title}</h3>
              <p class="mt-2 text-sm leading-7 text-ink-500">{v.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Affiliations (واقعی) -->
  <section class="px-5 lg:px-8 py-20">
    <div class="mx-auto max-w-5xl">
      <SectionHeading
        eyebrow="اعتبار ما"
        title="همکاری با سازمان‌های معتبر"
        subtitle="اعضای موسسه از اعتماد و همکاری نهادهای ملی و بین‌المللی برخوردار بوده‌اند."
      />
      <div class="mt-12 flex flex-wrap justify-center gap-4">
        {
          affiliations.map((a, i) => (
            <div
              class="reveal flex items-center gap-3 rounded-xl border border-ink-100 bg-white px-5 py-4"
              data-delay={`${i * 70}ms`}
            >
              <span class="grid place-items-center w-9 h-9 rounded-lg bg-brand-50 text-brand-600 shrink-0">
                <Icon name="award" class="w-5 h-5" />
              </span>
              <span class="font-semibold text-ink-700">{a}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>
