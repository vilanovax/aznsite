---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site.js';

const contactItems = [
  { icon: 'pin', label: 'آدرس', value: site.address },
  { icon: 'phone', label: 'تلفن', value: site.phone, href: `tel:${site.phoneHref}`, ltr: true },
  { icon: 'mail', label: 'ایمیل', value: site.email, href: `mailto:${site.email}`, ltr: true },
  { icon: 'clock', label: 'ساعات کاری', value: site.workingHours },
];
---

<BaseLayout title="تماس با ما" description="راه‌های ارتباطی با موسسه حسابرسی آزموده کاران.">
  <PageHero
    eyebrow="تماس با ما"
    title="با ما در ارتباط باشید"
    subtitle="برای دریافت مشاوره یا اطلاعات بیشتر درباره خدمات ما، از راه‌های زیر با ما در تماس باشید."
  />

  <section class="px-5 lg:px-8 py-20">
    <div class="mx-auto max-w-7xl grid lg:grid-cols-5 gap-10">
      <!-- Contact info -->
      <div class="lg:col-span-2 space-y-5">
        {
          contactItems.map((c, i) => (
            <div class="reveal flex items-start gap-4 rounded-2xl border border-ink-100 bg-white p-6" data-delay={`${i * 70}ms`}>
              <div class="grid place-items-center w-12 h-12 rounded-xl bg-brand-50 text-brand-600 shrink-0">
                <Icon name={c.icon} class="w-6 h-6" />
              </div>
              <div>
                <div class="text-sm text-ink-400">{c.label}</div>
                {c.href ? (
                  <a href={c.href} class="mt-1 block font-semibold text-ink-900 hover:text-brand-600 transition-colors" dir={c.ltr ? 'ltr' : undefined}>
                    {c.value}
                  </a>
                ) : (
                  <div class="mt-1 font-semibold text-ink-900 leading-7">{c.value}</div>
                )}
              </div>
            </div>
          ))
        }
      </div>

      <!-- Form -->
      <div class="lg:col-span-3 reveal" data-delay="100ms">
        <form
          class="rounded-2xl border border-ink-100 bg-white p-7 sm:p-9"
          onsubmit="event.preventDefault(); this.reset(); document.getElementById('form-success').classList.remove('hidden');"
        >
          <h2 class="text-xl font-bold text-ink-900">فرم درخواست مشاوره</h2>
          <p class="mt-2 text-sm text-ink-500">اطلاعات خود را وارد کنید؛ کارشناسان ما در اولین فرصت با شما تماس می‌گیرند.</p>

          <div class="mt-6 grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-ink-700 mb-1.5">نام و نام خانوادگی</label>
              <input id="name" name="name" type="text" required class="w-full rounded-lg border border-ink-200 px-4 py-2.5 text-ink-900 outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-ink-700 mb-1.5">شماره تماس</label>
              <input id="phone" name="phone" type="tel" required dir="ltr" class="w-full rounded-lg border border-ink-200 px-4 py-2.5 text-ink-900 outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
            </div>
          </div>
          <div class="mt-5">
            <label for="email" class="block text-sm font-medium text-ink-700 mb-1.5">ایمیل</label>
            <input id="email" name="email" type="email" dir="ltr" class="w-full rounded-lg border border-ink-200 px-4 py-2.5 text-ink-900 outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100" />
          </div>
          <div class="mt-5">
            <label for="message" class="block text-sm font-medium text-ink-700 mb-1.5">پیام شما</label>
            <textarea id="message" name="message" rows="5" required class="w-full rounded-lg border border-ink-200 px-4 py-2.5 text-ink-900 outline-none transition-colors focus:border-brand-500 focus:ring-2 focus:ring-brand-100 resize-y"></textarea>
          </div>

          <div id="form-success" class="hidden mt-5 rounded-lg bg-brand-50 border border-brand-200 px-4 py-3 text-sm text-brand-700">
            پیام شما با موفقیت ثبت شد. به‌زودی با شما تماس می‌گیریم.
          </div>

          <button type="submit" class="mt-6 w-full sm:w-auto inline-flex items-center justify-center gap-2 rounded-xl bg-brand-600 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-brand-700">
            ارسال پیام
            <Icon name="arrow" class="w-5 h-5" />
          </button>
          <p class="mt-4 text-xs text-ink-400">
            توجه: این فرم نمایشی است. برای فعال‌سازی ارسال واقعی، می‌توان آن را به سرویس ایمیل یا فرم متصل کرد.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
