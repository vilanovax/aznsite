# هدرهای امنیتی — برای Netlify و Cloudflare Pages
# (اگر روی سرور خودتان با nginx میزبانی می‌کنید، معادل این‌ها را در کانفیگ nginx بگذارید)
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'; upgrade-insecure-requests

# دارایی‌های هش‌دار و تغییرناپذیر — کش بلندمدت (بازدید مجدد سریع‌تر)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
